<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="TOP_CENTER" spacing="15.0" stylesheets="@style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.controller">
   <padding>
      <Insets bottom="20.0" left="30.0" right="30.0" top="20.0" />
   </padding>

   <Label styleClass="titulo" text="Compra en Cafetería" />

   <VBox spacing="5.0">
      <Label text="Cliente" />
      <TextField fx:id="txtNombre" promptText="Ingrese su nombre" />
   </VBox>

   <VBox spacing="5.0">
      <Label text="Bebida" />
      <ComboBox fx:id="cmbBebida" maxWidth="Infinity" promptText="Seleccione una bebida" />
   </VBox>

   <VBox spacing="5.0">
      <Label text="Cantidad" />
      <TextField fx:id="txtCantidad" onKeyPressed="#calcularOnEnter" promptText="Ingrese la cantidad" />
   </VBox>

   <CheckBox fx:id="chkPostre" mnemonicParsing="false" text="Agregar postre (RD$75.00)" />

   <HBox alignment="CENTER" spacing="15.0">
      <Button fx:id="btnCalcular" mnemonicParsing="false" onAction="#calcularAction" onMouseEntered="#onMouseEntered" onMouseExited="#onMouseExited" text="Calcular" />
      <Button fx:id="btnLimpiar" mnemonicParsing="false" onAction="#limpiarAction" styleClass="btn-secundario" text="Limpiar" />
   </HBox>

   <VBox spacing="5.0" styleClass="panel-resumen">
      <Label styleClass="subtitulo" text="Resumen:" />
      <Label fx:id="lblResumen" text="---" />
      <Label fx:id="lblMensaje" styleClass="mensaje-ayuda" text="Esperando datos de la compra..." />
   </VBox>
</VBox>